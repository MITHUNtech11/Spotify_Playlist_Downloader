# Copy this file to .env and fill in real values.
# Main downloader only requires DOWNLOAD_FOLDER.
# Spotify variables are used by scripts inside trial/.

DOWNLOAD_FOLDER=./Car_Songs

# Spotify app credentials (optional unless using trial scripts)
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret

# Playlist id (optional unless using trial scripts)
# Example: 0QLgslnaPVpLClLVjVDE3O
PLAYLIST_ID=your_playlist_id
